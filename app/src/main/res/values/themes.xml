<?xml version="1.0" encoding="utf-8"?>
<!-- App-Theme ohne AppCompat-Abhängigkeit. Compose übernimmt das eigentliche
     Styling; hier wird nur das Fenster (Hintergrund/Statusbar) dunkel gesetzt,
     damit beim Start kein heller Blitz erscheint. -->
<resources>
    <style name="Theme.TradingAnalyzer" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/card</item>
        <item name="android:navigationBarColor">@color/bg</item>
    </style>
</resources>
